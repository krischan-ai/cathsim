; Godot 4.4 project configuration for the CathSim VPP navigation client.
; Engine configuration file.
; Generated/authored for Stage 8 (see doc/05-开发进度记录.md).

config_version=5

[application]

config/name="CathSim VPP Client"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.4", "Forward Plus")

[display]

window/size/viewport_width=1280
window/size/viewport_height=720

[rendering]

renderer/rendering_method="forward_plus"

[network]

; Backend WebSocket endpoint (FastAPI service from services/main.py).
; Read by scripts/websocket_client.gd. Keyboard control (W/S/A/D, R) is handled
; via direct physical-key polling in scripts/input_handler.gd, so no custom
; InputMap actions are required here.
config/server_url="ws://localhost:8000/ws/session"
